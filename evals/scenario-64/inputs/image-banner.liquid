{% comment %}
  Dawn image-banner section — starter version without Files-library fallback
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div class="banner banner--{{ section.settings.image_overlay_opacity }}">
  {%- if section.settings.image != blank -%}
    {{
      section.settings.image
      | image_url: width: 3840
      | image_tag:
        class: 'banner__media',
        widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
        sizes: '100vw'
    }}
  {%- else -%}
    {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
  {%- endif -%}

  <div class="banner__content {{ section.settings.desktop_content_position }}">
    <div class="banner__box content-container">
      {%- if section.settings.heading != blank -%}
        <h2 class="banner__heading inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="banner__text rte inline-richtext">
          {{ section.settings.text }}
        </div>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="button button--primary">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image banner",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_overlay_opacity",
      "label": "Image overlay opacity",
      "options": [
        { "value": "opacity-0",   "label": "0%" },
        { "value": "opacity-10",  "label": "10%" },
        { "value": "opacity-20",  "label": "20%" },
        { "value": "opacity-30",  "label": "30%" },
        { "value": "opacity-40",  "label": "40%" },
        { "value": "opacity-50",  "label": "50%" }
      ],
      "default": "opacity-0"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2",  "label": "Small" },
        { "value": "h1",  "label": "Medium" },
        { "value": "h0",  "label": "Large" },
        { "value": "hxl", "label": "Extra large" }
      ],
      "default": "h1"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "label": "Desktop content position",
      "options": [
        { "value": "top-left",      "label": "Top left" },
        { "value": "top-center",    "label": "Top center" },
        { "value": "top-right",     "label": "Top right" },
        { "value": "middle-left",   "label": "Middle left" },
        { "value": "middle-center", "label": "Middle center" },
        { "value": "middle-right",  "label": "Middle right" },
        { "value": "bottom-left",   "label": "Bottom left" },
        { "value": "bottom-center", "label": "Bottom center" },
        { "value": "bottom-right",  "label": "Bottom right" }
      ],
      "default": "middle-left"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Image banner"
    }
  ]
}
{% endschema %}
