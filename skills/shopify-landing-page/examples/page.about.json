    "principles": {
      "type": "multicolumn",
      "blocks": {
        "p1": {
          "type": "column",
          "settings": {
            "title": "We don't drop-ship",
            "text": "<p>Every item passes through our warehouse. It gets inspected, photographed, and packed by a person — not a fulfillment robot in a country whose name you can't pronounce.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "p2": {
          "type": "column",
          "settings": {
            "title": "We don't run on algorithms",
            "text": "<p>Curation is humans only. Our team has career mechanics, weekend racers, and one ex-OEM product engineer. If we wouldn't put it in our own garage, it doesn't go in your box.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "p3": {
          "type": "column",
          "settings": {
            "title": "We don't lock you in",
            "text": "<p>Cancel, skip, swap, pause — all one click. No fees. No \"are you sure?\" dialogs. The whole point is monthly fun, not a trap.</p>",
            "link_label": "",
            "link": ""
          }
        }
      },
      "block_order": ["p1", "p2", "p3"],
      "settings": {
        "title": "Three principles",
        "heading_size": "h1",
        "image_width": "third",
        "image_ratio": "adapt",
