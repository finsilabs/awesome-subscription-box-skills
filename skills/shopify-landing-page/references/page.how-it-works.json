    "steps": {
      "type": "multicolumn",
      "blocks": {
        "step1": {
          "type": "column",
          "settings": {
            "title": "1. Pick your tier",
            "text": "<p>Choose Pit Stop ($54), Apex ($84), or Podium ($119). Sign up takes 90 seconds. No long-term commitment, no fine print, no fees for cancellation.</p><p>You can change tiers later — your account dashboard handles upgrades and downgrades with one click.</p>",
            "link_label": "Compare tiers",
            "link": "/collections/tiers"
          }
        },
        "step2": {
          "type": "column",
          "settings": {
            "title": "2. We curate",
            "text": "<p>The day after you subscribe, your account opens for an optional preferences profile: car platforms you own, sizes, what tools you already have. We use it to personalize and avoid duplicates.</p><p>Every month, our team picks the items by hand. Real people who wrench, drive, and track. Items are inspected before they go in the box.</p>",
            "link_label": "",
            "link": ""
          }
        },
        "step3": {
          "type": "column",
          "settings": {
            "title": "3. Box at your door",
            "text": "<p>Boxes ship the 15th of every month. Free US shipping on every tier. You'll get a tracking email when yours leaves the warehouse.</p><p>If a box ever feels light, our value guarantee covers it: refund, replace, or credit — your call.</p>",
            "link_label": "Our shipping policy",
            "link": "/policies/shipping-policy"
          }
        }
      },
      "block_order": ["step1", "step2", "step3"],
      "settings": {
        "title": "The three steps",
        "heading_size": "h1",
