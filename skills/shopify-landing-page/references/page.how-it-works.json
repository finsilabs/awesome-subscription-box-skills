    "calendar": {
      "type": "image-with-text",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "The monthly cadence",
            "heading_size": "h1"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p><strong>1st–10th</strong> — Subscribe by the 10th to get this month's drop. Anything later goes in the next batch.</p><p><strong>11th–14th</strong> — Curation team finalizes the list, items get pulled, packed, and inspected.</p><p><strong>15th</strong> — Boxes ship. You get a tracking email.</p><p><strong>16th–23rd</strong> — Your box arrives (most US addresses).</p><p><strong>Anytime</strong> — Cancel, skip, swap tier, or update your address from your account dashboard. No fees, no notice required.</p>",
            "text_style": "body"
          }
        }
